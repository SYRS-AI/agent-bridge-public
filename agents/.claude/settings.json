{
  "autoMemoryEnabled": true,
  "autoDreamEnabled": true,
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.agent-bridge/hooks/mark-idle.sh",
            "timeout": 3,
            "additionalContext": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.agent-bridge/hooks/clear-idle.sh",
            "timeout": 3
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.agent-bridge/hooks/prompt_timestamp.py",
            "timeout": 3,
            "additionalContext": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.agent-bridge/hooks/session-start.py",
            "timeout": 3,
            "additionalContext": true
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.agent-bridge/hooks/permission_escalation.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
