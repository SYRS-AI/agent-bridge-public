#!/usr/bin/env bash
# agent-bridge — primary Agent Bridge CLI

set -euo pipefail

SCRIPT_DIR="$(cd -P "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
# shellcheck source=/dev/null
source "$SCRIPT_DIR/bridge-lib.sh"
bridge_load_roster
CLI_NAME="$(basename "$0")"

usage() {
  cat <<EOF
Usage:
  $CLI_NAME status [--watch] [--refresh <seconds>] [--open-limit <count>] [--all-agents]
  $CLI_NAME list
  $CLI_NAME kill <number|all>
  $CLI_NAME urgent <agent> "<message>" [--wait <seconds>]
  $CLI_NAME task <create|inbox|show|claim|done|handoff|summary> ...
  $CLI_NAME profile <status|diff|deploy> ...
  $CLI_NAME setup <discord|agent> ...
  $CLI_NAME cron <inventory|show|list|create|update|delete|enqueue|sync|run-subagent|errors|cleanup> ...
  $CLI_NAME discord <status|sync>
  $CLI_NAME migrate workspace plan <agent>
  $CLI_NAME migrate workspace copy <agent> [--dry-run]
  $CLI_NAME migrate workspace cutover <agent> --dry-run
  $CLI_NAME inbox [agent] [--all]
  $CLI_NAME show <task-id>
  $CLI_NAME claim <task-id> [--agent <agent>] [--lease <seconds>]
  $CLI_NAME done <task-id> [--agent <agent>] [--note <text> | --note-file <path>]
  $CLI_NAME handoff <task-id> --to <agent> [--from <agent>] [--note <text> | --note-file <path>]
  $CLI_NAME summary [agent...]
  $CLI_NAME worktree list
  $CLI_NAME profile status [agent|--all]
  $CLI_NAME profile diff <agent>
  $CLI_NAME profile deploy <agent> [--dry-run] [--force]
  $CLI_NAME setup discord <agent> [--channel <id>]... [--openclaw-account <account>]
  $CLI_NAME setup agent <agent> [--skip-discord] [--test-start]
  $CLI_NAME discord status
  $CLI_NAME discord sync
  $CLI_NAME cron inventory [--mode recurring|one-shot|all] [--family <family>] [--limit <count>]
  $CLI_NAME cron show <job-name-or-id>
  $CLI_NAME cron list [--agent <bridge-agent>] [--enabled yes|no|all] [--limit <count>] [--json]
  $CLI_NAME cron create --agent <bridge-agent> --schedule "<cron-expr>" --title "<title>" [--payload "<text>" | --payload-file <path>] [--tz <iana-tz>]
  $CLI_NAME cron update <job-id> [--agent <bridge-agent>] [--schedule "<cron-expr>"] [--title "<title>"] [--payload "<text>" | --payload-file <path>] [--tz <iana-tz>] [--enable|--disable]
  $CLI_NAME cron delete <job-id>
  $CLI_NAME cron enqueue <job-name-or-id> [--slot <slot-key>] [--dry-run]
  $CLI_NAME cron sync [--dry-run] [--json] [--since <iso-datetime>] [--now <iso-datetime>]
  $CLI_NAME cron run-subagent <run-id> [--dry-run]
  $CLI_NAME cron errors report [--agent <bridge|openclaw>] [--family <family>] [--limit <count>] [--json]
  $CLI_NAME cron cleanup report [--mode expired-one-shot] [--json]
  $CLI_NAME cron cleanup prune [--mode expired-one-shot] [--dry-run]
  $CLI_NAME migrate workspace plan <agent>
  $CLI_NAME migrate workspace copy <agent> [--dry-run]
  $CLI_NAME migrate workspace cutover <agent> --dry-run
  $CLI_NAME --codex|--claude --name <agent> [--loop] [--no-continue] [--workdir <dir>] [--replace] [--no-attach] [--no-project-skill] [--prefer wake|new|shared]

Examples:
  $CLI_NAME status
  $CLI_NAME status --watch
  $CLI_NAME list
  $CLI_NAME kill 1
  $CLI_NAME kill all
  $CLI_NAME worktree list
  $CLI_NAME cron inventory --family memory-daily --limit 10
  $CLI_NAME cron list --agent main
  $CLI_NAME cron create --agent main --schedule "0 9 * * *" --title "일일 모니터링"
  $CLI_NAME cron enqueue <memory-daily-job-id> --slot 2026-04-05 --dry-run
  $CLI_NAME cron sync --dry-run
  $CLI_NAME cron run-subagent <run-id> --dry-run
  $CLI_NAME cron errors report --limit 20
  $CLI_NAME cron cleanup report
  $CLI_NAME setup discord tester
  $CLI_NAME setup agent tester
  $CLI_NAME migrate workspace plan <agent>
  $CLI_NAME migrate workspace copy <agent> --dry-run
  $CLI_NAME migrate workspace cutover <agent> --dry-run
  $CLI_NAME inbox developer
  $CLI_NAME task create --to tester --title "재테스트" --body-file ~/agent-bridge/shared/report.md
  $CLI_NAME claim 12 --agent tester
  $CLI_NAME urgent developer "[TESTER] 프로덕션 장애 확인 필요"
  $CLI_NAME --codex --name dev
  $CLI_NAME --codex --name qa --loop
  $CLI_NAME --claude --name reviewer --workdir /path/to/repo
  $CLI_NAME --codex --name worker-a --prefer new

By default, $CLI_NAME installs a project-local agent-bridge skill in the target workdir:
  Codex  -> .agents/skills/agent-bridge-project/SKILL.md
  Claude -> .claude/skills/agent-bridge-project/SKILL.md

If a same-name session is already active with different engine/workdir/loop settings,
$CLI_NAME will refuse to attach. Use \`$CLI_NAME kill <number>\` or rerun with \`--replace\`.

Primary command: \`agent-bridge\`
Short alias: \`agb\`
EOF
}

is_tty() {
  [[ -t 0 && -t 1 ]]
}

prompt_spawn_mode() {
  local can_create_worktree="$1"
  local project_root="$2"
  shift 2
  local candidates=("$@")
  local choice=""
  local index=1
  local candidate

  echo "[info] 현재 프로젝트에 비활성 정적 ${ENGINE} 역할이 있습니다: $project_root" >&2
  for candidate in "${candidates[@]}"; do
    printf '  %d. %s | session=%s | workdir=%s\n' \
      "$index" \
      "$candidate" \
      "$(bridge_agent_session "$candidate")" \
      "$(bridge_agent_workdir "$candidate")" >&2
    index=$((index + 1))
  done
  echo >&2
  echo "1) 기존 정적 역할 깨우기" >&2
  if [[ "$can_create_worktree" == "1" ]]; then
    echo "2) 새 isolated worktree worker 만들기 (권장)" >&2
    echo "3) 현재 checkout에서 새 dynamic worker 만들기" >&2
  else
    echo "2) 현재 checkout에서 새 dynamic worker 만들기" >&2
  fi

  while true; do
    printf '선택: ' >&2
    read -r choice
    case "$choice" in
      1)
        printf 'wake'
        return 0
        ;;
      2)
        if [[ "$can_create_worktree" == "1" ]]; then
          printf 'new'
        else
          printf 'shared'
        fi
        return 0
        ;;
      3)
        if [[ "$can_create_worktree" == "1" ]]; then
          printf 'shared'
          return 0
        fi
        ;;
    esac
    echo "올바른 번호를 입력하세요." >&2
  done
}

prompt_static_candidate() {
  local candidates=("$@")
  local choice=""
  local index=1
  local candidate

  if [[ ${#candidates[@]} -eq 1 ]]; then
    printf '%s' "${candidates[0]}"
    return 0
  fi

  echo "[info] 깨울 정적 역할을 선택하세요." >&2
  for candidate in "${candidates[@]}"; do
    printf '  %d. %s | workdir=%s\n' "$index" "$candidate" "$(bridge_agent_workdir "$candidate")" >&2
    index=$((index + 1))
  done

  while true; do
    printf '역할 번호: ' >&2
    read -r choice
    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#candidates[@]} )); then
      printf '%s' "${candidates[$((choice - 1))]}"
      return 0
    fi
    echo "올바른 번호를 입력하세요." >&2
  done
}

start_static_agent() {
  local agent="$1"
  local static_workdir
  local start_args=()

  static_workdir="$(bridge_agent_workdir "$agent")"
  if [[ $INSTALL_PROJECT_SKILL -eq 1 ]]; then
    bridge_bootstrap_project_skill "$(bridge_agent_engine "$agent")" "$static_workdir" || true
  fi

  "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-daemon.sh" ensure >/dev/null

  if [[ $REPLACE_MODE -eq 1 ]]; then
    start_args+=(--replace)
  fi
  if [[ $ATTACH_MODE -eq 1 ]]; then
    start_args+=(--attach)
  fi

  exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-start.sh" "$agent" "${start_args[@]}"
}

if [[ $# -gt 0 ]]; then
  case "$1" in
    list)
      if [[ $# -ne 1 ]]; then
      bridge_die "Usage: $CLI_NAME list"
      fi
      bridge_list_active_agents_numbered
      exit 0
      ;;
    status)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-status.sh" "$@"
      ;;
    kill)
      if [[ $# -ne 2 ]]; then
        bridge_die "Usage: $CLI_NAME kill <number|all>"
      fi

      if [[ "$2" == "all" ]]; then
        bridge_kill_all_active_agents
      else
        bridge_kill_active_agent_by_index "$2"
      fi
      exit 0
      ;;
    urgent)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-send.sh" --urgent "$@"
      ;;
    task)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-task.sh" "$@"
      ;;
    profile)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-profile.sh" "$@"
      ;;
    setup)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-setup.sh" "$@"
      ;;
    cron)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-cron.sh" "$@"
      ;;
    discord)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-discord-relay.sh" "$@"
      ;;
    migrate)
      shift
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-migrate.sh" "$@"
      ;;
    worktree)
      shift
      case "${1:-}" in
        list|"")
          if [[ $# -gt 1 ]]; then
            bridge_die "Usage: $CLI_NAME worktree list"
          fi
          bridge_list_worktrees
          exit 0
          ;;
        *)
          bridge_die "지원하지 않는 worktree 명령입니다: $1"
          ;;
      esac
      ;;
    inbox|show|claim|done|handoff|summary|create)
      exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-task.sh" "$@"
      ;;
  esac
fi

ENGINE=""
NAME=""
WORKDIR="$(pwd)"
WORKDIR_EXPLICIT=0
LOOP_MODE=0
CONTINUE_MODE=1
ATTACH_MODE=1
REPLACE_MODE=0
INSTALL_PROJECT_SKILL=1
SPAWN_PREFERENCE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --codex)
      ENGINE="codex"
      shift
      ;;
    --claude)
      ENGINE="claude"
      shift
      ;;
    --name)
      [[ $# -lt 2 ]] && bridge_die "--name 뒤에 에이전트 이름을 지정하세요."
      NAME="$2"
      shift 2
      ;;
    --loop)
      LOOP_MODE=1
      shift
      ;;
    --no-continue)
      CONTINUE_MODE=0
      shift
      ;;
    --continue)
      CONTINUE_MODE=1
      shift
      ;;
    --workdir)
      [[ $# -lt 2 ]] && bridge_die "--workdir 뒤에 경로를 지정하세요."
      WORKDIR="$2"
      WORKDIR_EXPLICIT=1
      shift 2
      ;;
    --replace)
      REPLACE_MODE=1
      shift
      ;;
    --no-attach)
      ATTACH_MODE=0
      shift
      ;;
    --no-project-skill)
      INSTALL_PROJECT_SKILL=0
      shift
      ;;
    --prefer)
      [[ $# -lt 2 ]] && bridge_die "--prefer 뒤에 wake|new|shared 중 하나를 지정하세요."
      SPAWN_PREFERENCE="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      bridge_die "알 수 없는 옵션: $1"
      ;;
  esac
done

[[ -z "$ENGINE" ]] && bridge_die "--codex 또는 --claude 중 하나를 지정하세요."
[[ -z "$NAME" ]] && bridge_die "--name은 필수입니다."

if ! bridge_validate_agent_name "$NAME"; then
  bridge_die "이름은 영문/숫자/점/밑줄/하이픈만 허용합니다: $NAME"
fi

case "$SPAWN_PREFERENCE" in
  ""|wake|new|shared)
    ;;
  *)
    bridge_die "--prefer 는 wake|new|shared 중 하나여야 합니다."
    ;;
esac

WORKDIR="$(cd "$WORKDIR" && pwd -P)"

if bridge_agent_exists "$NAME" && [[ "$(bridge_agent_source "$NAME")" == "static" ]]; then
  STATIC_ENGINE="$(bridge_agent_engine "$NAME")"
  STATIC_WORKDIR="$(bridge_agent_workdir "$NAME")"

  if [[ "$STATIC_ENGINE" != "$ENGINE" ]]; then
    bridge_die "'$NAME'은(는) ${STATIC_ENGINE} 정적 역할입니다. 요청 엔진(${ENGINE})과 다릅니다."
  fi
  if [[ $WORKDIR_EXPLICIT -eq 1 && "$WORKDIR" != "$STATIC_WORKDIR" ]]; then
    bridge_die "'$NAME' 정적 역할은 workdir이 고정되어 있습니다: $STATIC_WORKDIR"
  fi
  if [[ "$WORKDIR" != "$STATIC_WORKDIR" ]]; then
    echo "[info] '$NAME' 정적 역할의 고정 workdir을 사용합니다: $STATIC_WORKDIR"
    WORKDIR="$STATIC_WORKDIR"
  fi

  start_static_agent "$NAME"
fi

PROJECT_ROOT="$(bridge_project_root_for_path "$WORKDIR")"
IS_GIT_PROJECT=0
if git -C "$WORKDIR" rev-parse --show-toplevel >/dev/null 2>&1; then
  IS_GIT_PROJECT=1
fi

mapfile -t STATIC_CANDIDATES < <(bridge_static_agents_for_project_engine "$PROJECT_ROOT" "$ENGINE")
if [[ ${#STATIC_CANDIDATES[@]} -gt 0 ]]; then
  if [[ -z "$SPAWN_PREFERENCE" ]] && is_tty; then
    SPAWN_PREFERENCE="$(prompt_spawn_mode "$IS_GIT_PROJECT" "$PROJECT_ROOT" "${STATIC_CANDIDATES[@]}")"
    echo
  elif [[ -z "$SPAWN_PREFERENCE" ]]; then
    SPAWN_PREFERENCE="shared"
  fi

  case "$SPAWN_PREFERENCE" in
    wake)
      if is_tty; then
        WAKE_AGENT="$(prompt_static_candidate "${STATIC_CANDIDATES[@]}")"
      elif [[ ${#STATIC_CANDIDATES[@]} -eq 1 ]]; then
        WAKE_AGENT="${STATIC_CANDIDATES[0]}"
      else
        bridge_die "깨울 정적 역할이 여러 개입니다. TTY에서 선택하거나 --name 으로 정적 역할을 직접 지정하세요."
      fi
      echo "[info] 새 dynamic worker '$NAME' 대신 정적 역할 '$WAKE_AGENT'를 깨웁니다."
      start_static_agent "$WAKE_AGENT"
      ;;
    new)
      if [[ "$IS_GIT_PROJECT" != "1" ]]; then
        bridge_die "현재 경로는 git 프로젝트가 아니어서 isolated worktree를 만들 수 없습니다: $WORKDIR"
      fi
      WORKDIR="$(bridge_prepare_isolated_worktree "$ENGINE" "$NAME" "$WORKDIR")"
      echo "[info] isolated worktree를 사용합니다: $WORKDIR"
      ;;
    shared)
      :
      ;;
  esac
fi

ACTIVE_FILE="$(bridge_dynamic_agent_file_for "$NAME")"
HISTORY_FILE="$(bridge_history_file_for "$ENGINE" "$NAME" "$WORKDIR")"
SESSION_ID=""

if [[ $INSTALL_PROJECT_SKILL -eq 1 ]]; then
  bridge_bootstrap_project_skill "$ENGINE" "$WORKDIR" || true
fi

if [[ -f "$ACTIVE_FILE" ]]; then
  bridge_load_roster
  if bridge_agent_is_active "$NAME" && [[ $REPLACE_MODE -eq 0 ]]; then
    EXISTING_ENGINE="$(bridge_agent_engine "$NAME")"
    EXISTING_WORKDIR="$(bridge_agent_workdir "$NAME")"
    EXISTING_LOOP="$(bridge_agent_loop "$NAME")"
    EXISTING_CONTINUE="$(bridge_agent_continue "$NAME")"

    if [[ "$EXISTING_ENGINE" != "$ENGINE" || "$EXISTING_WORKDIR" != "$WORKDIR" || "$EXISTING_LOOP" != "$LOOP_MODE" || "$EXISTING_CONTINUE" != "$CONTINUE_MODE" ]]; then
      bridge_die "'$NAME' 세션이 이미 실행 중이지만 요청한 설정과 다릅니다. existing: engine=$EXISTING_ENGINE workdir=$EXISTING_WORKDIR loop=$EXISTING_LOOP continue=$EXISTING_CONTINUE | requested: engine=$ENGINE workdir=$WORKDIR loop=$LOOP_MODE continue=$CONTINUE_MODE | '$CLI_NAME kill <number>' 또는 '--replace'를 사용하세요."
    fi

    echo "[info] '$NAME' 세션이 이미 실행 중입니다. 기존 세션에 연결합니다."
    if [[ $ATTACH_MODE -eq 1 ]]; then
      bridge_attach_tmux_session "$(bridge_agent_session "$NAME")"
    fi
    exit 0
  fi
fi

if [[ $CONTINUE_MODE -eq 1 && -f "$HISTORY_FILE" ]]; then
  AGENT_SESSION_ID=""
  # shellcheck source=/dev/null
  source "$HISTORY_FILE"
  SESSION_ID="${AGENT_SESSION_ID:-}"
fi

bridge_add_agent_id_if_missing "$NAME"
# shellcheck disable=SC2034
BRIDGE_AGENT_DESC["$NAME"]="Ad hoc ${ENGINE} agent (${WORKDIR})"
# shellcheck disable=SC2034
BRIDGE_AGENT_ENGINE["$NAME"]="$ENGINE"
# shellcheck disable=SC2034
BRIDGE_AGENT_SESSION["$NAME"]="$NAME"
# shellcheck disable=SC2034
BRIDGE_AGENT_WORKDIR["$NAME"]="$WORKDIR"
# shellcheck disable=SC2034
BRIDGE_AGENT_SOURCE["$NAME"]="dynamic"
# shellcheck disable=SC2034
BRIDGE_AGENT_META_FILE["$NAME"]="$ACTIVE_FILE"
# shellcheck disable=SC2034
BRIDGE_AGENT_LOOP["$NAME"]="$LOOP_MODE"
# shellcheck disable=SC2034
BRIDGE_AGENT_CONTINUE["$NAME"]="$CONTINUE_MODE"
# shellcheck disable=SC2034
BRIDGE_AGENT_SESSION_ID["$NAME"]="$SESSION_ID"
# shellcheck disable=SC2034
BRIDGE_AGENT_HISTORY_KEY["$NAME"]="$(bridge_history_key_for "$ENGINE" "$NAME" "$WORKDIR")"
# shellcheck disable=SC2034
BRIDGE_AGENT_CREATED_AT["$NAME"]="$(date +%s)"
# shellcheck disable=SC2034
BRIDGE_AGENT_UPDATED_AT["$NAME"]="$(bridge_now_iso)"
bridge_write_dynamic_agent_file "$NAME" "$ACTIVE_FILE"

"$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-daemon.sh" ensure >/dev/null

START_ARGS=()
if [[ $REPLACE_MODE -eq 1 ]]; then
  START_ARGS+=(--replace)
fi
if [[ $ATTACH_MODE -eq 1 ]]; then
  START_ARGS+=(--attach)
fi

exec "$BRIDGE_BASH_BIN" "$SCRIPT_DIR/bridge-start.sh" "$NAME" "${START_ARGS[@]}"
